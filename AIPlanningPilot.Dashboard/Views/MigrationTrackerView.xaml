<UserControl x:Class="AIPlanningPilot.Dashboard.Views.MigrationTrackerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:converters="clr-namespace:AIPlanningPilot.Dashboard.Converters"
             xmlns:models="clr-namespace:AIPlanningPilot.Dashboard.Models">

    <UserControl.Resources>
        <converters:MigrationStatusToColorConverter x:Key="MigrationStatusToColorConverter" />
        <converters:ComplexityTierToColorConverter x:Key="ComplexityTierToColorConverter" />
        <converters:DoubleToGridLengthConverter x:Key="DoubleToGridLengthConverter" />
    </UserControl.Resources>

    <Grid>
        <!-- Loading indicator -->
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility="{Binding IsLoaded, Converter={StaticResource InverseBoolToVisibilityConverter}}">
            <mah:ProgressRing IsActive="True" Width="60" Height="60" />
            <TextBlock Text="Loading migration data..." Margin="0,12,0,0" HorizontalAlignment="Center"
                       Foreground="{DynamicResource MahApps.Brushes.Gray3}" />
        </StackPanel>

        <!-- Empty state: no MIGRATION.md -->
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="400"
                    Visibility="{Binding HasMigrationFile, Converter={StaticResource InverseBoolToVisibilityConverter}}">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding IsLoaded}" Value="True" />
                                <Condition Binding="{Binding HasMigrationFile}" Value="False" />
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Visibility" Value="Visible" />
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>
            <iconPacks:PackIconPhosphorIcons Kind="FileMagnifyingGlass" Width="48" Height="48"
                                             HorizontalAlignment="Center"
                                             Foreground="{DynamicResource MahApps.Brushes.Gray3}" />
            <TextBlock Text="No Migration Data" FontSize="18" FontWeight="SemiBold"
                       HorizontalAlignment="Center" Margin="0,12,0,4" />
            <TextBlock Text="Create main/MIGRATION.md in the restructuring repo to start tracking entity migration progress."
                       TextAlignment="Center" TextWrapping="Wrap"
                       Foreground="{DynamicResource MahApps.Brushes.Gray3}" />
        </StackPanel>

        <!-- Content (visible when loaded AND file exists) -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
            <ScrollViewer.Style>
                <Style TargetType="ScrollViewer">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding IsLoaded}" Value="True" />
                                <Condition Binding="{Binding HasMigrationFile}" Value="True" />
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Visibility" Value="Visible" />
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </ScrollViewer.Style>

            <StackPanel>
                <!-- ======== KPI Strip ======== -->
                <UniformGrid Rows="1" Margin="0,0,0,16">
                    <!-- Total Entities -->
                    <Border Background="{DynamicResource MahApps.Brushes.Accent}"
                            CornerRadius="6" Padding="16" Margin="0,0,6,0">
                        <StackPanel>
                            <TextBlock Text="ENTITIES WITH UI" FontSize="10" Foreground="White" Opacity="0.8"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{Binding TotalEntitiesWithUi}" FontSize="28" FontWeight="Bold"
                                       Foreground="White" />
                            <TextBlock Text="of 331 total entities" FontSize="11" Foreground="White" Opacity="0.7" />
                        </StackPanel>
                    </Border>
                    <!-- Migrated -->
                    <Border Background="{StaticResource App.Brushes.CardBackground}"
                            BorderBrush="{DynamicResource MahApps.Brushes.Gray8}" BorderThickness="1"
                            CornerRadius="6" Padding="16" Margin="3,0">
                        <StackPanel>
                            <TextBlock Text="MIGRATED" FontSize="10" Foreground="{DynamicResource MahApps.Brushes.Gray3}"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{Binding MigratedCount}" FontSize="28" FontWeight="Bold"
                                       Foreground="#4CAF50" />
                            <TextBlock Text="entities completed" FontSize="11"
                                       Foreground="{DynamicResource MahApps.Brushes.Gray3}" />
                        </StackPanel>
                    </Border>
                    <!-- In Progress -->
                    <Border Background="{StaticResource App.Brushes.CardBackground}"
                            BorderBrush="{DynamicResource MahApps.Brushes.Gray8}" BorderThickness="1"
                            CornerRadius="6" Padding="16" Margin="3,0">
                        <StackPanel>
                            <TextBlock Text="IN PROGRESS" FontSize="10" Foreground="{DynamicResource MahApps.Brushes.Gray3}"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{Binding InProgressCount}" FontSize="28" FontWeight="Bold"
                                       Foreground="#FFC107" />
                            <TextBlock Text="being worked on" FontSize="11"
                                       Foreground="{DynamicResource MahApps.Brushes.Gray3}" />
                        </StackPanel>
                    </Border>
                    <!-- Not Started -->
                    <Border Background="{StaticResource App.Brushes.CardBackground}"
                            BorderBrush="{DynamicResource MahApps.Brushes.Gray8}" BorderThickness="1"
                            CornerRadius="6" Padding="16" Margin="3,0">
                        <StackPanel>
                            <TextBlock Text="NOT STARTED" FontSize="10" Foreground="{DynamicResource MahApps.Brushes.Gray3}"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{Binding NotStartedCount}" FontSize="28" FontWeight="Bold"
                                       Foreground="{DynamicResource MahApps.Brushes.Gray3}" />
                            <TextBlock Text="awaiting migration" FontSize="11"
                                       Foreground="{DynamicResource MahApps.Brushes.Gray3}" />
                        </StackPanel>
                    </Border>
                    <!-- Manual Overrides -->
                    <Border Background="{StaticResource App.Brushes.CardBackground}"
                            BorderBrush="{DynamicResource MahApps.Brushes.Gray8}" BorderThickness="1"
                            CornerRadius="6" Padding="16" Margin="6,0,0,0">
                        <StackPanel>
                            <TextBlock Text="MANUAL OVERRIDES" FontSize="10" Foreground="{DynamicResource MahApps.Brushes.Gray3}"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{Binding ManualOverrideCount}" FontSize="28" FontWeight="Bold"
                                       Foreground="#F44336" />
                            <TextBlock Text="with MANUAL markers" FontSize="11"
                                       Foreground="{DynamicResource MahApps.Brushes.Gray3}" />
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- ======== Overall Progress Bar ======== -->
                <Border Background="{StaticResource App.Brushes.CardBackground}"
                        BorderBrush="{DynamicResource MahApps.Brushes.Gray8}" BorderThickness="1"
                        CornerRadius="6" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,8">
                            <TextBlock Text="Overall Migration Progress" FontSize="14" FontWeight="SemiBold"
                                       DockPanel.Dock="Left" />
                            <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource MahApps.Brushes.Accent}">
                                <TextBlock.Text>
                                    <Binding Path="OverallProgressPercent" StringFormat="{}{0:F1}%" />
                                </TextBlock.Text>
                            </TextBlock>
                        </DockPanel>
                        <Grid Height="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="{Binding DonePercent, Converter={StaticResource DoubleToGridLengthConverter}}" />
                                <ColumnDefinition Width="{Binding InProgressPercent, Converter={StaticResource DoubleToGridLengthConverter}}" />
                                <ColumnDefinition Width="{Binding RemainingPercent, Converter={StaticResource DoubleToGridLengthConverter}}" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="#4CAF50" CornerRadius="5,0,0,5" />
                            <Border Grid.Column="1" Background="#FFC107" />
                            <Border Grid.Column="2" Background="{DynamicResource MahApps.Brushes.Gray8}"
                                    CornerRadius="0,5,5,0" />
                        </Grid>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                                <Border Width="10" Height="10" CornerRadius="2" Background="#4CAF50"
                                        VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock FontSize="12" Foreground="{DynamicResource MahApps.Brushes.Gray3}">
                                    <Run Text="Migrated (" /><Run Text="{Binding MigratedCount, Mode=OneWay}" /><Run Text=")" />
                                </TextBlock>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                                <Border Width="10" Height="10" CornerRadius="2" Background="#FFC107"
                                        VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock FontSize="12" Foreground="{DynamicResource MahApps.Brushes.Gray3}">
                                    <Run Text="In Progress (" /><Run Text="{Binding InProgressCount, Mode=OneWay}" /><Run Text=")" />
                                </TextBlock>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="10" Height="10" CornerRadius="2"
                                        Background="{DynamicResource MahApps.Brushes.Gray8}"
                                        VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock FontSize="12" Foreground="{DynamicResource MahApps.Brushes.Gray3}">
                                    <Run Text="Not Started (" /><Run Text="{Binding NotStartedCount, Mode=OneWay}" /><Run Text=")" />
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ======== Complexity Tier Summary ======== -->
                <UniformGrid Rows="1" Margin="0,0,0,16">
                    <Border Background="{StaticResource App.Brushes.CardBackground}"
                            BorderBrush="{DynamicResource MahApps.Brushes.Gray8}" BorderThickness="1"
                            CornerRadius="6" Padding="14" Margin="0,0,4,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="SIMPLE" FontSize="10" FontWeight="SemiBold" Foreground="#2196F3"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding SimpleTierCount}" FontSize="24" FontWeight="Bold"
                                       Foreground="#2196F3" HorizontalAlignment="Center" />
                            <TextBlock Text="8 props or fewer" FontSize="10"
                                       Foreground="{DynamicResource MahApps.Brushes.Gray3}"
                                       HorizontalAlignment="Center" />
                            <Border Height="4" CornerRadius="2" Background="#2196F3" Margin="16,6,16,0" />
                        </StackPanel>
                    </Border>
                    <Border Background="{StaticResource App.Brushes.CardBackground}"
                            BorderBrush="{DynamicResource MahApps.Brushes.Gray8}" BorderThickness="1"
                            CornerRadius="6" Padding="14" Margin="4,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="MEDIUM" FontSize="10" FontWeight="SemiBold" Foreground="#FFC107"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding MediumTierCount}" FontSize="24" FontWeight="Bold"
                                       Foreground="#FFC107" HorizontalAlignment="Center" />
                            <TextBlock Text="8-20 props, FKs, tabs" FontSize="10"
                                       Foreground="{DynamicResource MahApps.Brushes.Gray3}"
                                       HorizontalAlignment="Center" />
                            <Border Height="4" CornerRadius="2" Background="#FFC107" Margin="16,6,16,0" />
                        </StackPanel>
                    </Border>
                    <Border Background="{StaticResource App.Brushes.CardBackground}"
                            BorderBrush="{DynamicResource MahApps.Brushes.Gray8}" BorderThickness="1"
                            CornerRadius="6" Padding="14" Margin="4,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="COMPLEX" FontSize="10" FontWeight="SemiBold" Foreground="#FF9800"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding ComplexTierCount}" FontSize="24" FontWeight="Bold"
                                       Foreground="#FF9800" HorizontalAlignment="Center" />
                            <TextBlock Text="20+ props, state machines" FontSize="10"
                                       Foreground="{DynamicResource MahApps.Brushes.Gray3}"
                                       HorizontalAlignment="Center" />
                            <Border Height="4" CornerRadius="2" Background="#FF9800" Margin="16,6,16,0" />
                        </StackPanel>
                    </Border>
                    <Border Background="{StaticResource App.Brushes.CardBackground}"
                            BorderBrush="{DynamicResource MahApps.Brushes.Gray8}" BorderThickness="1"
                            CornerRadius="6" Padding="14" Margin="4,0,0,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="VERY COMPLEX" FontSize="10" FontWeight="SemiBold" Foreground="#F44336"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding VeryComplexTierCount}" FontSize="24" FontWeight="Bold"
                                       Foreground="#F44336" HorizontalAlignment="Center" />
                            <TextBlock Text="Custom handlers + printing" FontSize="10"
                                       Foreground="{DynamicResource MahApps.Brushes.Gray3}"
                                       HorizontalAlignment="Center" />
                            <Border Height="4" CornerRadius="2" Background="#F44336" Margin="16,6,16,0" />
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- ======== Filter Controls ======== -->
                <Border Background="{StaticResource App.Brushes.CardBackground}"
                        BorderBrush="{DynamicResource MahApps.Brushes.Gray8}" BorderThickness="1"
                        CornerRadius="6" Padding="12" Margin="0,0,0,16">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconPhosphorIcons Kind="FunnelSimple" Width="16" Height="16"
                                                         VerticalAlignment="Center" Margin="0,0,8,0"
                                                         Foreground="{DynamicResource MahApps.Brushes.Gray3}" />
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Width="220" VerticalAlignment="Center" Margin="0,0,12,0"
                                 mah:TextBoxHelper.Watermark="Search entities..."
                                 mah:TextBoxHelper.ClearTextButton="True" />
                        <TextBlock Text="Status:" VerticalAlignment="Center" Margin="0,0,6,0"
                                   Foreground="{DynamicResource MahApps.Brushes.Gray3}" FontSize="12" />
                        <ComboBox ItemsSource="{Binding StatusFilters}"
                                  SelectedItem="{Binding SelectedStatusFilter}"
                                  Width="120" VerticalAlignment="Center" Margin="0,0,12,0" />
                        <TextBlock Text="Complexity:" VerticalAlignment="Center" Margin="0,0,6,0"
                                   Foreground="{DynamicResource MahApps.Brushes.Gray3}" FontSize="12" />
                        <ComboBox ItemsSource="{Binding ComplexityFilters}"
                                  SelectedItem="{Binding SelectedComplexityFilter}"
                                  Width="130" VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- ======== Domain Cards ======== -->
                <ItemsControl ItemsSource="{Binding DomainGroups}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:DomainMigrationGroup}">
                            <Border Background="{StaticResource App.Brushes.CardBackground}"
                                    BorderBrush="{DynamicResource MahApps.Brushes.Gray8}" BorderThickness="1"
                                    CornerRadius="6" Padding="16" Margin="0,0,0,10">
                                <StackPanel>
                                    <!-- Domain header -->
                                    <DockPanel Margin="0,0,0,8">
                                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                            <iconPacks:PackIconPhosphorIcons Kind="Package" Width="16" Height="16"
                                                                             VerticalAlignment="Center" Margin="0,0,8,0"
                                                                             Foreground="{DynamicResource MahApps.Brushes.Accent}" />
                                            <TextBlock Text="{Binding DomainName}" FontSize="15" FontWeight="SemiBold"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                                            <Border Background="{DynamicResource MahApps.Brushes.Gray8}"
                                                    CornerRadius="10" Padding="8,2" Margin="0,0,8,0">
                                                <TextBlock FontSize="11"
                                                           Foreground="{DynamicResource MahApps.Brushes.Gray2}">
                                                    <Run Text="{Binding DoneCount, Mode=OneWay}" /><Run Text="/" /><Run Text="{Binding EntityCount, Mode=OneWay}" />
                                                </TextBlock>
                                            </Border>
                                            <TextBlock FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource MahApps.Brushes.Gray3}"
                                                       VerticalAlignment="Center">
                                                <TextBlock.Text>
                                                    <Binding Path="ProgressPercent" StringFormat="{}{0:F0}%" />
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </StackPanel>
                                    </DockPanel>

                                    <!-- Domain progress bar -->
                                    <Grid Height="6" Margin="0,0,0,10">
                                        <Border Background="{DynamicResource MahApps.Brushes.Gray8}"
                                                CornerRadius="3" />
                                        <ProgressBar Value="{Binding ProgressPercent}" Maximum="100"
                                                     Height="6" Background="Transparent"
                                                     Foreground="#4CAF50" BorderThickness="0" />
                                    </Grid>

                                    <!-- Entity tags (WrapPanel) -->
                                    <ItemsControl ItemsSource="{Binding Entities}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type models:MigrationEntity}">
                                                <Border CornerRadius="4" Padding="8,4" Margin="0,0,4,4"
                                                        Background="{Binding Status, Converter={StaticResource MigrationStatusToColorConverter}}"
                                                        ToolTipService.InitialShowDelay="0"
                                                        BorderThickness="2"
                                                        Cursor="Hand">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="BorderBrush" Value="Transparent" />
                                                            <Setter Property="Opacity" Value="0.85" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsMouseOver}" Value="True">
                                                                    <Setter Property="BorderBrush"
                                                                            Value="{Binding Complexity, Converter={StaticResource ComplexityTierToColorConverter}}" />
                                                                    <Setter Property="Opacity" Value="1.0" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding Name}" FontSize="11"
                                                               Foreground="White" FontWeight="SemiBold" />
                                                    <Border.ToolTip>
                                                        <ToolTip Padding="0" BorderThickness="0" Background="Transparent">
                                                            <Border CornerRadius="6" Background="#FF484850" BorderBrush="#FF5A5A62"
                                                                    BorderThickness="1" Padding="12,10" MinWidth="210">
                                                                <StackPanel>
                                                                    <TextBlock Text="{Binding Name}" FontSize="14"
                                                                               FontWeight="Bold" Foreground="White" />
                                                                    <TextBlock Text="{Binding Domain}" FontSize="11"
                                                                               Foreground="#FF9E9E9E" Margin="0,2,0,0" />
                                                                    <Separator Background="#FF5A5A62" Margin="0,8,0,8" />
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="90" />
                                                                            <ColumnDefinition Width="*" />
                                                                        </Grid.ColumnDefinitions>
                                                                        <Grid.RowDefinitions>
                                                                            <RowDefinition Height="22" />
                                                                            <RowDefinition Height="22" />
                                                                            <RowDefinition Height="22" />
                                                                            <RowDefinition Height="22" />
                                                                            <RowDefinition Height="22" />
                                                                        </Grid.RowDefinitions>
                                                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Complexity"
                                                                                   Foreground="#FF9E9E9E" VerticalAlignment="Center" />
                                                                        <TextBlock Grid.Row="0" Grid.Column="1"
                                                                                   Text="{Binding Complexity}" FontWeight="SemiBold"
                                                                                   Foreground="{Binding Complexity, Converter={StaticResource ComplexityTierToColorConverter}}"
                                                                                   VerticalAlignment="Center" />
                                                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Properties"
                                                                                   Foreground="#FF9E9E9E" VerticalAlignment="Center" />
                                                                        <TextBlock Grid.Row="1" Grid.Column="1"
                                                                                   Text="{Binding PropertyCount}" FontWeight="SemiBold"
                                                                                   Foreground="White" VerticalAlignment="Center" />
                                                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Has UI"
                                                                                   Foreground="#FF9E9E9E" VerticalAlignment="Center" />
                                                                        <TextBlock Grid.Row="2" Grid.Column="1"
                                                                                   Text="{Binding HasUi}" FontWeight="SemiBold"
                                                                                   Foreground="White" VerticalAlignment="Center" />
                                                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Manual Code"
                                                                                   Foreground="#FF9E9E9E" VerticalAlignment="Center" />
                                                                        <TextBlock Grid.Row="3" Grid.Column="1"
                                                                                   Text="{Binding HasManualCode}" FontWeight="SemiBold"
                                                                                   Foreground="White" VerticalAlignment="Center" />
                                                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Status"
                                                                                   Foreground="#FF9E9E9E" VerticalAlignment="Center" />
                                                                        <TextBlock Grid.Row="4" Grid.Column="1"
                                                                                   Text="{Binding Status}" FontWeight="SemiBold"
                                                                                   Foreground="White" VerticalAlignment="Center" />
                                                                    </Grid>
                                                                </StackPanel>
                                                            </Border>
                                                        </ToolTip>
                                                    </Border.ToolTip>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

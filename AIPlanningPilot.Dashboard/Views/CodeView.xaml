<UserControl x:Class="AIPlanningPilot.Dashboard.Views.CodeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
             xmlns:views="clr-namespace:AIPlanningPilot.Dashboard.Views">
    <avalonedit:TextEditor x:Name="TextEditor"
                           IsReadOnly="True"
                           ShowLineNumbers="True"
                           FontFamily="Cascadia Code, Consolas, Courier New"
                           FontSize="13"
                           Padding="8"
                           Background="{DynamicResource MahApps.Brushes.ThemeBackground}"
                           Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}"
                           HorizontalScrollBarVisibility="Auto"
                           VerticalScrollBarVisibility="Auto"
                           views:CodeViewBehavior.DocumentText="{Binding Content}"
                           views:CodeViewBehavior.HighlightingName="{Binding SyntaxHighlighting}" />
</UserControl>

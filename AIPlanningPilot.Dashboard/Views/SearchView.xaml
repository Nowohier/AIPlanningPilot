<UserControl x:Class="AIPlanningPilot.Dashboard.Views.SearchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:models="clr-namespace:AIPlanningPilot.Dashboard.Models">

    <DockPanel>
        <!-- Result count + loading indicator -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
            <mah:ProgressRing IsActive="{Binding IsSearching}" Width="16" Height="16"
                              Margin="0,0,8,0"
                              Visibility="{Binding IsSearching, Converter={StaticResource BoolToVisibilityConverter}}" />
            <TextBlock Foreground="{DynamicResource MahApps.Brushes.Gray3}"
                       Visibility="{Binding HasSearched, Converter={StaticResource BoolToVisibilityConverter}}">
                <Run Text="{Binding ResultCount, Mode=OneWay}" />
                <Run Text=" results found" />
            </TextBlock>
        </StackPanel>

        <!-- Results list -->
        <ListView ItemsSource="{Binding Results}" BorderThickness="0" Margin="-10,0,0,0"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListView.ItemTemplate>
                <DataTemplate DataType="{x:Type models:SearchResult}">
                    <Border Padding="8,6" Cursor="Hand"
                            BorderThickness="0,0,0,1"
                            BorderBrush="{DynamicResource MahApps.Brushes.Gray8}">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick"
                                          Command="{Binding DataContext.NavigateToResultCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                          CommandParameter="{Binding}" />
                        </Border.InputBindings>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                <iconPacks:PackIconPhosphorIcons Kind="FileText" Width="12" Height="12"
                                                                  VerticalAlignment="Center" Margin="0,0,6,0"
                                                                  Foreground="{DynamicResource MahApps.Brushes.Accent}" />
                                <TextBlock Text="{Binding FileName}" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MahApps.Brushes.Accent}" FontSize="12" />
                                <TextBlock Foreground="{DynamicResource MahApps.Brushes.Gray3}" FontSize="11" Margin="8,0,0,0">
                                    <Run Text="Line " /><Run Text="{Binding LineNumber, Mode=OneWay}" />
                                </TextBlock>
                            </StackPanel>
                            <TextBlock Text="{Binding MatchedLine}" TextWrapping="Wrap"
                                       FontFamily="Cascadia Code, Consolas, Courier New" FontSize="12"
                                       Foreground="{DynamicResource MahApps.Brushes.Gray2}" />
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </DockPanel>
</UserControl>

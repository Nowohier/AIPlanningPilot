<UserControl x:Class="AIPlanningPilot.Dashboard.Views.HandoverView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:models="clr-namespace:AIPlanningPilot.Dashboard.Models"
             Loaded="View_Loaded">

    <Grid>
        <!-- Loading indicator -->
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility="{Binding IsLoaded, Converter={StaticResource InverseBoolToVisibilityConverter}}">
            <mah:ProgressRing IsActive="True" Width="60" Height="60" />
            <TextBlock Text="Loading handovers..." Margin="0,12,0,0" HorizontalAlignment="Center"
                       Foreground="{DynamicResource MahApps.Brushes.Gray3}" />
        </StackPanel>

        <!-- Content -->
        <DockPanel Margin="10"
                   Visibility="{Binding IsLoaded, Converter={StaticResource BoolToVisibilityConverter}}">
            <!-- Developer selector -->
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
                <TextBlock Text="Developer:" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold" />
                <ComboBox ItemsSource="{Binding Handovers}"
                          SelectedItem="{Binding SelectedHandover}"
                          Width="280" HorizontalAlignment="Left">
                    <ComboBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:HandoverNotes}">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconPhosphorIcons Kind="User" Width="14" Height="14"
                                                                  VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock VerticalAlignment="Center">
                                    <Run Text="{Binding DeveloperName, Mode=OneWay}" />
                                    <Run Text=" (" /><Run Text="{Binding LastUpdated, Mode=OneWay}" /><Run Text=")" />
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>

            <!-- Selected handover content -->
            <ContentPresenter Content="{Binding SelectedHandover}">
                <ContentPresenter.ContentTemplate>
                    <DataTemplate DataType="{x:Type models:HandoverNotes}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <!-- FOR NEXT SESSION -->
                                <HeaderedContentControl Style="{StaticResource App.Styles.CardControl}"
                                                        Header="FOR NEXT SESSION" Margin="0,0,0,12">
                                    <ItemsControl ItemsSource="{Binding ForNextSession}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <DockPanel Margin="0,4">
                                                    <iconPacks:PackIconPhosphorIcons Kind="ArrowRight" Width="12" Height="12"
                                                                                      DockPanel.Dock="Left"
                                                                                      VerticalAlignment="Top" Margin="0,3,8,0"
                                                                                      Foreground="{DynamicResource MahApps.Brushes.Accent}" />
                                                    <TextBlock Text="{Binding}" TextWrapping="Wrap" FontSize="13" />
                                                </DockPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </HeaderedContentControl>

                                <!-- Open Threads + Decisions & Findings side by side -->
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Open Threads -->
                                    <HeaderedContentControl Grid.Column="0"
                                                            Style="{StaticResource App.Styles.CardControl}"
                                                            Header="OPEN THREADS">
                                        <ItemsControl ItemsSource="{Binding OpenThreads}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <DockPanel Margin="0,4">
                                                        <iconPacks:PackIconPhosphorIcons Kind="CircleDashed" Width="12" Height="12"
                                                                                          DockPanel.Dock="Left"
                                                                                          VerticalAlignment="Top" Margin="0,3,6,0"
                                                                                          Foreground="{DynamicResource MahApps.Brushes.Accent}" />
                                                        <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                                                    </DockPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </HeaderedContentControl>

                                    <!-- Decisions & Findings -->
                                    <HeaderedContentControl Grid.Column="2"
                                                            Style="{StaticResource App.Styles.CardControl}"
                                                            Header="DECISIONS &amp; FINDINGS">
                                        <ItemsControl ItemsSource="{Binding DecisionsAndFindings}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <DockPanel Margin="0,4">
                                                        <iconPacks:PackIconPhosphorIcons Kind="Check" Width="12" Height="12"
                                                                                          DockPanel.Dock="Left"
                                                                                          VerticalAlignment="Top" Margin="0,3,6,0"
                                                                                          Foreground="{DynamicResource MahApps.Brushes.Accent}" />
                                                        <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                                                    </DockPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </HeaderedContentControl>
                                </Grid>

                                <!-- FROM LAST SESSION -->
                                <HeaderedContentControl Style="{StaticResource App.Styles.CardControl}"
                                                        Header="FROM LAST SESSION">
                                    <ItemsControl ItemsSource="{Binding FromLastSession}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <DockPanel Margin="0,4">
                                                    <iconPacks:PackIconPhosphorIcons Kind="ArrowRight" Width="12" Height="12"
                                                                                      DockPanel.Dock="Left"
                                                                                      VerticalAlignment="Top" Margin="0,3,8,0"
                                                                                      Foreground="{DynamicResource MahApps.Brushes.Accent}" />
                                                    <TextBlock Text="{Binding}" TextWrapping="Wrap" FontSize="13" />
                                                </DockPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </HeaderedContentControl>
                            </StackPanel>
                        </ScrollViewer>
                    </DataTemplate>
                </ContentPresenter.ContentTemplate>
            </ContentPresenter>
        </DockPanel>
    </Grid>
</UserControl>

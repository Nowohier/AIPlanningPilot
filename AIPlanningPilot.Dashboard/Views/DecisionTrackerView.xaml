<UserControl x:Class="AIPlanningPilot.Dashboard.Views.DecisionTrackerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:models="clr-namespace:AIPlanningPilot.Dashboard.Models"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             Loaded="View_Loaded">
    <Grid>
        <!-- Loading indicator -->
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility="{Binding IsLoaded, Converter={StaticResource InverseBoolToVisibilityConverter}}">
            <mah:ProgressRing IsActive="True" Width="60" Height="60" />
            <TextBlock Text="Loading decisions..." Margin="0,12,0,0" HorizontalAlignment="Center"
                       Foreground="{DynamicResource MahApps.Brushes.Gray3}" />
        </StackPanel>

        <!-- Content -->
        <Grid Visibility="{Binding IsLoaded, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" MinWidth="250" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left: Decision list -->
            <DockPanel Grid.Column="0">
                <!-- Header -->
                <Border DockPanel.Dock="Top" Padding="12,10">
                    <TextBlock Text="ARCHITECTURAL DECISIONS" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource MahApps.Brushes.Accent}" />
                </Border>
                <Separator DockPanel.Dock="Top" Background="{DynamicResource MahApps.Brushes.Gray8}" Margin="12,0" />

                <!-- Decision list -->
                <ListBox ItemsSource="{Binding Decisions}"
                         SelectedItem="{Binding SelectedDecision}"
                         BorderThickness="0" Padding="6,4"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource MahApps.Styles.ListBoxItem}">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0,2" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="ItemBorder"
                                                Background="{StaticResource App.Brushes.CardBackground}"
                                                CornerRadius="{StaticResource App.CornerRadius.Card}"
                                                Padding="10,8" Cursor="Hand">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ItemBorder" Property="Background"
                                                        Value="{DynamicResource MahApps.Brushes.Gray8}" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="ItemBorder" Property="Background"
                                                        Value="{DynamicResource MahApps.Brushes.Accent}" />
                                                <Setter Property="Foreground" Value="White" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:Decision}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="{DynamicResource MahApps.Brushes.Accent}"
                                            CornerRadius="3" Padding="6,1" Margin="0,0,8,0">
                                        <TextBlock Text="{Binding Number, StringFormat='ADR {0:D3}'}"
                                                   Foreground="White" FontSize="11" FontWeight="Bold" />
                                    </Border>
                                    <TextBlock x:Name="DateText" Text="{Binding Date}" FontSize="11"
                                               Foreground="{DynamicResource MahApps.Brushes.Gray3}"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold"
                                           TextWrapping="Wrap" Margin="0,4,0,0" />
                                <TextBlock x:Name="PhaseText" Text="{Binding Phase}" FontSize="11"
                                           Foreground="{DynamicResource MahApps.Brushes.Gray3}"
                                           Margin="0,2,0,0" />
                            </StackPanel>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                    <Setter TargetName="DateText" Property="Foreground" Value="White" />
                                    <Setter TargetName="PhaseText" Property="Foreground" Value="White" />
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center"
                          VerticalAlignment="Stretch" Background="{DynamicResource MahApps.Brushes.Gray8}" />

            <!-- Right: Decision detail (rendered markdown in WebView2) -->
            <Border Grid.Column="2" Padding="8,0,0,0">
                <wv2:WebView2 x:Name="DecisionWebView"
                              DefaultBackgroundColor="Transparent" />
            </Border>
        </Grid>
    </Grid>
</UserControl>
